# Copy to .env for local dev. On Vercel, set this in Project → Settings → Environment Variables
# (must be present at build time — redeploy after adding/changing).
#
# Use your Railway public URL, HTTPS, no trailing slash, e.g.:
# VITE_API_BASE_URL=https://your-service.up.railway.app
VITE_API_BASE_URL=http://localhost:8000
